<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Maximum line length: 120 (ignores imports and URLs) -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- Tabs are not allowed, use spaces only -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- File must end with a newline -->
    <module name="NewlineAtEndOfFile"/>

    <module name="TreeWalker">

        <!-- ===== IMPORTS ===== -->

        <!-- Unused imports are not allowed -->
        <module name="UnusedImports"/>

        <!-- Wildcard imports are not allowed (e.g. import java.util.*) -->
        <module name="AvoidStarImport"/>

        <!-- Imports must be ordered: static first, then by group -->
        <module name="ImportOrder">
            <property name="groups" value="java,javax,jakarta,org,com"/>
            <property name="ordered" value="true"/>
            <property name="separated" value="true"/>
            <property name="option" value="top"/>
            <property name="sortStaticImportsAlphabetically" value="true"/>
        </module>

        <!-- ===== VARIABLES AND DECLARATIONS ===== -->

        <!-- Unused local variables are not allowed -->
        <module name="UnusedLocalVariable"/>

        <!-- Each variable must be declared on its own line -->
        <module name="MultipleVariableDeclarations"/>

        <!-- Modifiers must follow standard order (public static final, etc.) -->
        <module name="ModifierOrder"/>

        <!-- ===== NAMING ===== -->

        <!-- Classes and interfaces must use PascalCase -->
        <module name="TypeName"/>

        <!-- Methods must use camelCase -->
        <module name="MethodName"/>

        <!-- Parameters must use camelCase -->
        <module name="ParameterName"/>

        <!-- Local variables must use camelCase -->
        <module name="LocalVariableName"/>

        <!-- Constants (static final) must use UPPER_SNAKE_CASE -->
        <module name="ConstantName"/>

        <!-- Instance fields must use camelCase -->
        <module name="MemberName"/>

        <!-- Package names must be lowercase with no underscores -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- ===== BRACES AND BLOCKS ===== -->

        <!-- Braces are required for if/else/for/while/do -->
        <module name="NeedBraces"/>

        <!-- Opening brace must be on the same line -->
        <module name="LeftCurly"/>

        <!-- Closing brace must be on its own line -->
        <module name="RightCurly"/>

        <!-- Empty blocks are not allowed (e.g. empty catch) -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>

        <!-- ===== WHITESPACE ===== -->

        <!-- Indentation must be 4 spaces -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="arrayInitIndent" value="4"/>
            <property name="lineWrappingIndentation" value="8"/>
        </module>

        <!-- Whitespace is required after commas and semicolons -->
        <module name="WhitespaceAfter">
            <property name="tokens" value="COMMA, SEMI"/>
        </module>

        <!-- No whitespace before commas or semicolons -->
        <module name="NoWhitespaceBefore">
            <property name="tokens" value="COMMA, SEMI, POST_INC, POST_DEC"/>
        </module>

        <!-- Trailing whitespace is not allowed -->
        <module name="Regexp">
            <property name="format" value="[ \t]+$"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="Trailing whitespace is not allowed."/>
        </module>

        <!-- ===== BEST PRACTICES ===== -->

        <!-- System.out/err usage is not allowed, use a logger instead -->
        <module name="Regexp">
            <property name="format" value="System\.(out|err)\.print"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="Use a logger instead of System.out/err."/>
        </module>

        <!-- printStackTrace() is not allowed, use a logger instead -->
        <module name="Regexp">
            <property name="format" value="\.printStackTrace\(\)"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="Use a logger instead of printStackTrace()."/>
        </module>

        <!-- Maximum number of method parameters: 7 -->
        <module name="ParameterNumber">
            <property name="max" value="7"/>
        </module>

        <!-- Maximum cyclomatic complexity: 10 -->
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>
        </module>

        <!-- Multiple consecutive blank lines are not allowed -->
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="allowMultipleEmptyLines" value="false"/>
            <property name="allowMultipleEmptyLinesInsideClassMembers" value="false"/>
        </module>

        <!-- Unnecessary parentheses are not allowed -->
        <module name="UnnecessaryParentheses"/>

        <!-- Explicit comparison with true/false is not allowed (e.g. if (x == true)) -->
        <module name="SimplifyBooleanExpression"/>

        <!-- Redundant boolean returns are not allowed (e.g. if (x) return true; else return false;) -->
        <module name="SimplifyBooleanReturn"/>

        <!-- clone() is not allowed -->
        <module name="NoClone"/>

        <!-- finalizer is not allowed -->
        <module name="NoFinalizer"/>

    </module>
</module>
